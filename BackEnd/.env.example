# ==========================================
# ORBIT BACKEND - ENVIRONMENT VARIABLES
# ==========================================

# --- Core Server ---
PORT=8000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/skillswap
JWT_SECRET=your_super_secret_jwt_key
CORS_ORIGIN=https://your-frontend-domain.com

# --- Security & Admin ---
# Used to access the hidden /admin dashboard
ADMIN_SECRET=your_super_secret_admin_password

# --- Scalability & Performance ---
# Mongoose connection pooling (Tune for Atlas Free Tier)
DB_MAX_POOL=10
DB_MIN_POOL=1
DB_TIMEOUT_MS=5000

# Redis (Required for multi-instance Socket.io scaling & Bull Queues)
REDIS_URL=redis://localhost:6379

# --- ML & AI Integration ---
HUGGINGFACE_API_KEY=your_huggingface_key
GROQ_API_KEY=your_groq_key
ML_AUDIO_MODERATION_ENABLED=true

# --- OAuth Providers ---
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# --- Email Notifications (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# --- Cloudinary (Media/Avatars) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
